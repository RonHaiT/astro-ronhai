---
import HeaderLink from "./HeaderLink.astro";
import { SITE_TITLE } from "../consts";
import SunMoon from "./SunMoon.astro";
---

<nav class="bg-base-100 shadow">
  <div
    class="container mx-auto max-w-7xl px-4 flex justify-between items-center h-16"
  >
    <div class="flex items-center gap-2">
      <div class="lg:hidden dropdown">
        <svg
          tabindex="0"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          class="size-6"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M3.75 5.25h16.5m-16.5 4.5h16.5m-16.5 4.5h16.5m-16.5 4.5h16.5"
          ></path>
        </svg>

        <ul
          tabindex="0"
          class="menu menu-sm dropdown-content mt-3 z-[1] p-2 shadow bg-base-100 rounded-box w-52"
        >
          <li><a href="/">首页</a></li>
          <li><a href="/categories">分类</a></li>
          <li><a href="/tags">标签</a></li>
          <li><a href="/about">关于</a></li>
        </ul>
      </div>

      <a class="hidden lg:inline btn btn-ghost text-xl" href="/">{SITE_TITLE}</a
      >
    </div>

    <div class="hidden lg:flex">
      <ul class="menu menu-horizontal px-1">
        <li><a href="/">首页</a></li>
        <li><a href="/categories">分类</a></li>
        <li><a href="/tags">标签</a></li>
        <li><a href="/about">关于</a></li>
      </ul>
    </div>
    <SunMoon />
  </div>
</nav>
